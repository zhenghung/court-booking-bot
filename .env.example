# Court Booking Bot Configuration
# You can use either numeric IDs (e.g., 7935) or court names (e.g., "Pickleball Court P1")
# Court names support case-insensitive partial matching (e.g., "P1" matches "Pickleball Court P1")
# Booking Name and Contact are automatically fetched from the API after login
# Unit ID must be provided as it's not available from the API

GPROP_EMAIL=your_email@example.com
GPROP_PASSWORD=your_password
GPROP_FACILITY_IDS=Pickleball Court P1,Pickleball Court P2,Pickleball Court P3
# GPROP_FACILITY_IDS=7935,7936,7937
GPROP_UNIT_ID=1-XXXXX
GPROP_TARGET_DAY=friday

# Booking plan: time_slot>court1,court2,court3 (priority order)
# Books 7-9am with court priority: P3, P1, P2
GPROP_BOOKING_PLAN=07:00-09:00>Pickleball Court P3,Pickleball Court P1,Pickleball Court P2
# GPROP_BOOKING_PLAN=07:00-09:00>P3,P1,P2

# Telegram notifications
GPROP_TELEGRAM_BOT_TOKEN=
GPROP_TELEGRAM_CHAT_ID=
