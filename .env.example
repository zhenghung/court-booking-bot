# === Single Account Config (legacy, still supported) ===
GPROP_EMAIL=your_email@example.com
GPROP_PASSWORD=your_password
GPROP_FACILITY_IDS=7935,7936,7937
GPROP_UNIT_ID=1-135735
GPROP_BOOKING_NAME=YOUR NAME
GPROP_CONTACT=60123456789
GPROP_TARGET_DAY=friday
GPROP_BOOKING_PLAN=07:00-08:00>7935,7937,7936;08:00-09:00>7937,7936,7935

# === Multi-Account Config (optional, overrides single account) ===
# Account 1
GPROP_ACCOUNT_1_NAME=Fanny
GPROP_ACCOUNT_1_EMAIL=account1@example.com
GPROP_ACCOUNT_1_PASSWORD=password1
GPROP_ACCOUNT_1_UNIT_ID=1-135735
GPROP_ACCOUNT_1_BOOKING_NAME=NAME FOR ACCOUNT 1
GPROP_ACCOUNT_1_CONTACT=60123456789
GPROP_ACCOUNT_1_BOOKING_PLAN=07:00-08:00>7937,7936;08:00-09:00>7937,7936

# Account 2
GPROP_ACCOUNT_2_NAME=John
GPROP_ACCOUNT_2_EMAIL=account2@example.com
GPROP_ACCOUNT_2_PASSWORD=password2
GPROP_ACCOUNT_2_UNIT_ID=1-135735
GPROP_ACCOUNT_2_BOOKING_NAME=NAME FOR ACCOUNT 2
GPROP_ACCOUNT_2_CONTACT=60123456789
GPROP_ACCOUNT_2_BOOKING_PLAN=09:00-10:00>7937,7936;10:00-11:00>7937,7936

# Telegram notifications
GPROP_TELEGRAM_BOT_TOKEN=
GPROP_TELEGRAM_CHAT_ID=
